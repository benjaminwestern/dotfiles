{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "file:///Users/benjaminwestern/.config/opencode/plugins/mise.ts"
  ],
  "share": "disabled",
  "provider": {},
  "tools": {
    "bash": true,
    "edit": true,
    "write": true,
    "read": true,
    "grep": true,
    "glob": true,
    "list": true,
    "patch": true,
    "todowrite": true,
    "todoread": true,
    "webfetch": true
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow"
  },
  "mcp": {
    "google-developer-knowledge": {
      "type": "remote",
      "url": "https://developerknowledge.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "{env:GOOGLE_MCP_DEV_SERVER_API_KEY}"
      },
      "enabled": true
    },
    "terraform": {
      "type": "local",
      "command": ["terraform-mcp-server"],
      "enabled": true
    }
  }
}
