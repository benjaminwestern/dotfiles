# API keys for assistant/model providers.
# Copy this file to ~/.config/mise/.env and fill in real values.
# This file is gitignored; never commit secrets.

KIMI_API_KEY=
OPENCODE_API_KEY=
FIREWORKS_API_KEY=
GOOGLE_MCP_DEV_SERVER_API_KEY=

# Optional: TLS certificate variables when behind a corporate proxy.
# See bootstrap Zscaler handling for details.
SSL_CERT_FILE=
SSL_CERT_DIR=
REQUESTS_CA_BUNDLE=
CERT_PATH=
CERT_DIR=
CURL_CA_BUNDLE=
GRPC_DEFAULT_SSL_ROOTS_FILE_PATH=
NODE_EXTRA_CA_CERTS=
GIT_SSL_CAINFO=
