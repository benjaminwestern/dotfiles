{
  "$schema": "https://raw.githubusercontent.com/steipete/mcporter/main/mcporter.schema.json",
  // Unified MCP source for CLI access.
  // Entries here are CLI-visible definitions.
  "imports": [],
  "mcpServers": {
    // https://github.com/sooperset/mcp-atlassian
    "atlassian": {
      "description": "Access Jira and Confluence through Atlassian MCP. Use for searching issues/pages, reading project context, and updating Atlassian work items.",
      "command": "uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "JIRA_URL": "$env:ATLASSIAN_JIRA_URL",
        "JIRA_USERNAME": "$env:ATLASSIAN_USERNAME",
        "JIRA_API_TOKEN": "$env:ATLASSIAN_API_TOKEN",
        "CONFLUENCE_URL": "$env:ATLASSIAN_CONFLUENCE_URL",
        "CONFLUENCE_USERNAME": "$env:ATLASSIAN_USERNAME",
        "CONFLUENCE_API_TOKEN": "$env:ATLASSIAN_API_TOKEN"
      }
    },
    // https://github.com/ChromeDevTools/chrome-devtools-mcp
    "chrome-dev-tools": {
      "description": "Control and inspect Chrome through DevTools MCP. Use for browser debugging, page inspection, console/network analysis, and UI verification.",
      "command": "bunx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    // https://firebase.google.com/docs/ai-assistance/mcp-server
    "firebase": {
      "description": "Use Firebase project and app tooling through Firebase MCP. Use for Firebase setup, app inspection, deployment help, and Firebase-specific operations.",
      "command": "npx",
      "args": ["-y", "firebase-tools@latest", "mcp"]
    },
    // https://www.npmjs.com/package/@google-cloud/cloud-run-mcp
    "cloud-run": {
      "description": "Use Google Cloud Run MCP for Cloud Run service inspection, deployment support, and runtime operations.",
      "command": "npx",
      "args": ["-y", "@google-cloud/cloud-run-mcp"]
    },
    // https://www.npmjs.com/package/@google-cloud/gcloud-mcp
    "gcloud": {
      "description": "Run Google Cloud CLI workflows through gcloud MCP. Use for Google Cloud project, resource, and command-line operations.",
      "command": "npx",
      "args": ["-y", "@google-cloud/gcloud-mcp"]
    },
    // https://github.com/hashicorp/terraform-mcp-server
    "terraform": {
      "description": "Search Terraform Registry providers, modules, policies, and documentation. Use for current Terraform resource/module details and version lookup.",
      "command": "terraform-mcp-server"
    },
    // https://pkg.go.dev/golang.org/x/tools/gopls
    // https://go.dev/gopls/features/mcp
    "gopls": {
      "description": "Go language intelligence via gopls MCP: workspace/package context, symbols, references, diagnostics, APIs, vuln checks, and refactors. This entry is detached mode (`gopls mcp`): saved files only; run mcporter from the Go module/workspace root. Attached mode uses `gopls serve -mcp.listen=localhost:8092` and `http://localhost:8092/sessions/1` to share an active LSP session and unsaved editor buffers; use only when that matters.",
      "command": "gopls",
      "args": ["mcp"]
    },
    // https://github.com/benjaminwestern/agentic-interaction
    "agentic-interaction": {
      "description": "Connect to the local agentic-interaction MCP service. Use for local workflow automation and agent coordination tools exposed by that server.",
      "baseUrl": "http://127.0.0.1:8765/mcp"
    },
    // https://developers.google.com/knowledge/mcp#gemini-code-assist
    "google-developer-knowledge": {
      "description": "Search and retrieve official Google developer documentation. Use for Google Cloud, Firebase, Android, Chrome, Go, Gemini, TensorFlow, and web.dev answers.",
      "baseUrl": "https://developerknowledge.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "$env:GOOGLE_MCP_DEV_SERVER_API_KEY"
      }
    },
    // https://soloterm.com/#features
    "solo": {
      "description": "Connect to Solo's local MCP integration. Use for tools and workflows exposed by the Solo desktop app.",
      "command": "/Applications/Solo.app/Contents/MacOS/mcp"
    }
  }
}
